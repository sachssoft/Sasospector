<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:controls="using:Sachssoft.Sasospector.Views"
					x:ClassModifier="internal">

	<ControlTheme x:Key="{x:Type controls:InspectorPropertyView}"
				  TargetType="controls:InspectorPropertyView">

		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderMidBrush}"/>
		<Setter Property="BorderThickness" Value="{DynamicResource ThemeBorderThickness}"/>
		<Setter Property="Padding" Value="10"/>
		<Setter Property="Template">
			<ControlTemplate TargetType="controls:InspectorPropertyView">
				<Grid ColumnDefinitions="Auto,5, *">
					<Label Content="{TemplateBinding Header}"
						   Grid.Column="0"
						   Width="{Binding $parent[controls:InspectorControl].HeaderWidth}"
						   HorizontalAlignment="Stretch"
						   VerticalAlignment="Stretch"
						   HorizontalContentAlignment ="Right"
						   VerticalContentAlignment ="Top"
						   Padding="5 5 5 0"/>
					<GridSplitter Grid.Column="1"
								  Width="5"
								  HorizontalAlignment="Stretch"
								  VerticalAlignment="Stretch"
								  ResizeDirection="Columns"
								  Background="Transparent"/>
					<ContentControl Grid.Column="2"
									x:Name="PART_EditorContent"
									HorizontalAlignment="Stretch"
									VerticalAlignment="Stretch"/>

				</Grid>
			</ControlTemplate>
		</Setter>
	</ControlTheme>
	
</ResourceDictionary>

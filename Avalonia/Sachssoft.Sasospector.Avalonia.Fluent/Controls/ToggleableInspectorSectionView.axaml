<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:views="using:Sachssoft.Sasospector.Views"
					x:ClassModifier="internal">

	<ControlTheme x:Key="{x:Type views:ToggleableInspectorSectionView}"
				  TargetType="views:ToggleableInspectorSectionView">

		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderMidBrush}"/>
		<Setter Property="BorderThickness" Value="{DynamicResource ThemeBorderThickness}"/>
		<Setter Property="Padding" Value="10"/>
		<Setter Property="Template">
			<ControlTemplate TargetType="views:ToggleableInspectorSectionView">
				<Expander Theme="{StaticResource InspectorSectionViewExpanderTheme}">
					<Expander.Header>
						<StackPanel Orientation="Horizontal">
							<CheckBox VerticalAlignment="Center"/>
							<ContentPresenter Content="{TemplateBinding Header}"
											  VerticalAlignment="Center"/>
						</StackPanel>
					</Expander.Header>
					<ItemsControl ItemsSource="{Binding $parent[views:ToggleableInspectorSectionView].Items}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Orientation="Vertical"
											Spacing="{Binding $parent[views:InspectorControl].PropertySpacing}" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
					</ItemsControl>
				</Expander>
			</ControlTemplate>
		</Setter>
	</ControlTheme>
</ResourceDictionary>

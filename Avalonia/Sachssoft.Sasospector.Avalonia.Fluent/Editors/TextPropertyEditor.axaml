<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:views="using:Sachssoft.Sasospector.Views"
					xmlns:editors="using:Sachssoft.Sasospector.Views.Editors"
					x:ClassModifier="internal">
	
	<ControlTheme x:Key="{x:Type editors:TextPropertyEditor}"
					  TargetType="editors:TextPropertyEditor">
		<Setter Property="Template">
			<ControlTemplate TargetType="editors:TextPropertyEditor">
				<Grid>
					<TextBox x:Name="PART_TextBox"/>
				</Grid>
			</ControlTemplate>
		</Setter>
	</ControlTheme>
	
</ResourceDictionary>

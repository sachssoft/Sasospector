<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:views="using:Sachssoft.Sasospector.Views"
					xmlns:converters="using:Sachssoft.Sasospector.Views.Converters"
					x:ClassModifier="internal">

	<ControlTheme x:Key="{x:Type views:CheckBoxPropertyViewItem}"
				  TargetType="views:CheckBoxPropertyViewItem">

		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderMidBrush}"/>
		<Setter Property="BorderThickness" Value="{DynamicResource ThemeBorderThickness}"/>
		<Setter Property="Padding" Value="10"/>
		<Setter Property="IsHeaderVisible" Value="True"/>
		<Setter Property="Template">
			<ControlTemplate TargetType="views:CheckBoxPropertyViewItem"
							 x:DataType="views:CheckBoxPropertyViewItem">
				<StackPanel Orientation="Vertical">
					<Grid ColumnDefinitions="Auto,5,*">
						<Grid IsVisible="{TemplateBinding IsHeaderVisible}"
							  Width="{Binding $parent[views:InspectorControl].HeaderWidth}"
							  HorizontalAlignment="Right"
							  ColumnDefinitions="*,Auto"
							  ColumnSpacing="5">
							<Label Grid.Column="0"
								   Content="{TemplateBinding Header}"
								   HorizontalAlignment="Right"
								   HorizontalContentAlignment="Right"
								   Padding="5 5 5 0"/>
							<CheckBox Grid.Column="1"
								      IsChecked="{TemplateBinding IsChecked, Mode=TwoWay}"
								      HorizontalAlignment="Right"/>
						</Grid>
						<GridSplitter Grid.Column="1"
									  Width="5"
									  HorizontalAlignment="Stretch"
									  VerticalAlignment="Stretch"
									  ResizeDirection="Columns"
									  Background="Transparent"
									  IsVisible="{TemplateBinding IsHeaderVisible}"/>
						<ContentControl Grid.Column="2"
										x:Name="PART_EditorContent"
										HorizontalAlignment="Stretch"
										VerticalAlignment="Stretch"/>

					</Grid>
					<ContentControl x:Name="PART_Container" />
				</StackPanel>
			</ControlTemplate>
		</Setter>
		<Style Selector="^[CheckBehavior=Enable]">
			<Style Selector="^[IsChecked=False] /template/ ContentControl#PART_EditorContent">
				<Setter Property="IsEnabled" Value="False"/>
			</Style>
		</Style>
		<Style Selector="^[CheckBehavior=Enable]">
			<Style Selector="^[IsChecked=True] /template/ ContentControl#PART_EditorContent">
				<Setter Property="IsEnabled" Value="True"/>
			</Style>
		</Style>
	</ControlTheme>

</ResourceDictionary>

<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:views="using:Sachssoft.Sasospector.Views"
					x:ClassModifier="internal">

	<ControlTheme x:Key="{x:Type views:ConditionalViewItemBase}"
				  TargetType="views:ConditionalViewItemBase">

		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderMidBrush}"/>
		<Setter Property="BorderThickness" Value="{DynamicResource ThemeBorderThickness}"/>
		<Setter Property="Padding" Value="10"/>
		<Setter Property="Template">
			<ControlTemplate TargetType="views:ConditionalViewItemBase">
				<ItemsControl ItemsSource="{Binding $parent[views:ConditionalViewItemBase].Items}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Vertical"
										Spacing="{Binding $parent[views:InspectorControl].SectionSpacing}"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
				</ItemsControl>
			</ControlTemplate>
		</Setter>
		<Style Selector="^[IsValueTypeMatched=False]">
			<Setter Property="IsVisible" Value="False" />
		</Style>
	</ControlTheme>
</ResourceDictionary>

<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:views="using:Sachssoft.Sasospector.Views"
					xmlns:editors="using:Sachssoft.Sasospector.Views.Editors"
					x:ClassModifier="internal">

	<ControlTheme x:Key="{x:Type views:CustomEditorContent}"
				  TargetType="views:CustomEditorContent">
		<Setter Property="Template">
			<ControlTemplate TargetType="views:CustomEditorContent">
				<ContentPresenter Content="{TemplateBinding Content}" />
			</ControlTemplate>
		</Setter>
	</ControlTheme>
</ResourceDictionary>

<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:views="using:Sachssoft.Sasospector.Views"
					x:ClassModifier="internal">

	<ControlTheme x:Key="{x:Type views:SectionView}"
				  TargetType="views:SectionView">

		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderMidBrush}"/>
		<Setter Property="BorderThickness" Value="{DynamicResource ThemeBorderThickness}"/>
		<Setter Property="Padding" Value="10"/>
		<Setter Property="Template">
			<ControlTemplate TargetType="views:SectionView">
				<Expander Theme="{StaticResource InspectorSectionViewExpanderTheme}"
						  Header="{TemplateBinding Header}">
					<ItemsControl ItemsSource="{Binding $parent[views:SectionView].Items}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Orientation="Vertical"
											Spacing="{Binding $parent[views:InspectorControl].PropertySpacing}" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
					</ItemsControl>
				</Expander>
			</ControlTemplate>
		</Setter>
	</ControlTheme>
</ResourceDictionary>

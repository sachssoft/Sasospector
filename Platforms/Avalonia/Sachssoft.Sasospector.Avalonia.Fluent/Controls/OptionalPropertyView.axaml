<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:views="using:Sachssoft.Sasospector.Views"
					xmlns:converters="using:Sachssoft.Sasospector.Views.Converters"
					x:ClassModifier="internal">

	<ControlTheme x:Key="{x:Type views:OptionalPropertyViewItem}"
				  TargetType="views:OptionalPropertyViewItem">

		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderMidBrush}"/>
		<Setter Property="BorderThickness" Value="{DynamicResource ThemeBorderThickness}"/>
		<Setter Property="Padding" Value="10"/>
		<Setter Property="IsHeaderVisible" Value="True"/>
		<Setter Property="Template">
			<ControlTemplate TargetType="views:OptionalPropertyViewItem"
							 x:DataType="views:OptionalPropertyViewItem">
				<StackPanel Orientation="Vertical">
					<Grid ColumnDefinitions="Auto,5,*">
						<Grid ColumnDefinitions="Auto,5,*"
							  IsVisible="{TemplateBinding IsHeaderVisible}">
							<Label Content="{TemplateBinding Header}"
								   Grid.Column="0"
								   Width="{Binding $parent[views:InspectorControl].HeaderWidth}"
								   HorizontalAlignment="Stretch"
								   VerticalAlignment="Stretch"
								   HorizontalContentAlignment ="Right"
								   VerticalContentAlignment ="Top"
								   Padding="5 5 5 0"/>
							<CheckBox Grid.Column="2"
									  IsChecked="{TemplateBinding HasValue}"/>
						</Grid>
						<GridSplitter Grid.Column="1"
									  Width="5"
									  HorizontalAlignment="Stretch"
									  VerticalAlignment="Stretch"
									  ResizeDirection="Columns"
									  Background="Transparent"
									  IsVisible="{TemplateBinding IsHeaderVisible}"/>
						<ContentControl Grid.Column="2"
										x:Name="PART_EditorContent"
										HorizontalAlignment="Stretch"
										VerticalAlignment="Stretch"/>

					</Grid>
					<ContentControl x:Name="PART_Container" />
				</StackPanel>
			</ControlTemplate>
		</Setter>
	</ControlTheme>

</ResourceDictionary>

<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:views="using:Sachssoft.Sasospector.Views"
					xmlns:converters="using:Sachssoft.Sasospector.Views.Converters"
					x:ClassModifier="internal">

	<converters:NullToBoolConverter x:Key="NullToBoolConverter" />

	<ControlTheme x:Key="{x:Type views:PropertyViewItem}"
				  TargetType="views:PropertyViewItem">

		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderMidBrush}"/>
		<Setter Property="BorderThickness" Value="{DynamicResource ThemeBorderThickness}"/>
		<Setter Property="Padding" Value="10"/>
		<Setter Property="IsHeaderVisible" Value="True"/>
		<Setter Property="Template">
			<ControlTemplate TargetType="views:PropertyViewItem"
							 x:DataType="views:PropertyViewItem">
				<StackPanel Orientation="Vertical">
					<Grid ColumnDefinitions="Auto,5,*">
						<Label Content="{TemplateBinding Header}"
							   IsVisible="{TemplateBinding IsHeaderVisible}"
							   Grid.Column="0"
							   Width="{Binding $parent[views:InspectorControl].HeaderWidth}"
							   HorizontalAlignment="Stretch"
							   VerticalAlignment="Stretch"
							   HorizontalContentAlignment ="Right"
							   VerticalContentAlignment ="Top"
							   Padding="5 5 5 0"/>
						<GridSplitter Grid.Column="1"
									  Width="5"
									  HorizontalAlignment="Stretch"
									  VerticalAlignment="Stretch"
									  ResizeDirection="Columns"
									  Background="Transparent"
									  IsVisible="{TemplateBinding IsHeaderVisible}"/>
						<ContentControl Grid.Column="2"
										x:Name="PART_EditorContent"
										HorizontalAlignment="Stretch"
										VerticalAlignment="Stretch"/>
					</Grid>
					<ContentControl x:Name="FooterContent"
									IsVisible="{TemplateBinding Footer, Converter={StaticResource NullToBoolConverter}}"
									Content="{TemplateBinding Footer}"
									HorizontalAlignment="Stretch"
									VerticalAlignment="Stretch"
									TextBlock.TextWrapping="WrapWithOverflow"
									Padding="{DynamicResource InspectorDescriptionPadding}"
									FontSize="{DynamicResource InspectorDescriptionFontSize}"
									Foreground="{DynamicResource InspectorDescriptionForeground}"/>
				</StackPanel>
			</ControlTemplate>
		</Setter>
		<Style Selector="^[HeaderLayout=Stacked]">
			<Setter Property="Template">
				<ControlTemplate TargetType="views:PropertyViewItem"
								 x:DataType="views:PropertyViewItem">
					<StackPanel Orientation="Vertical">
						<StackPanel Orientation="Horizontal">
							<Label Content="{TemplateBinding Header}"
								   IsVisible="{TemplateBinding IsHeaderVisible}"
								   Width="{Binding $parent[views:InspectorControl].HeaderWidth}"
								   HorizontalAlignment="Stretch"
								   VerticalAlignment="Stretch"
								   HorizontalContentAlignment ="Right"
								   VerticalContentAlignment ="Top"
								   Padding="5 5 5 0"/>
							<ContentControl x:Name="PART_EditorContent"
											HorizontalAlignment="Stretch"
											VerticalAlignment="Stretch"/>
						</StackPanel>
						<ContentControl x:Name="FooterContent"
										IsVisible="{TemplateBinding Footer, Converter={StaticResource NullToBoolConverter}}"
										Content="{TemplateBinding Footer}"
										HorizontalAlignment="Stretch"
										VerticalAlignment="Stretch"
										TextBlock.TextWrapping="WrapWithOverflow"
										Padding="{DynamicResource InspectorDescriptionPadding}"
										FontSize="{DynamicResource InspectorDescriptionFontSize}"
										Foreground="{DynamicResource InspectorDescriptionForeground}"/>
					</StackPanel>
				</ControlTemplate>
			</Setter>
		</Style>
	</ControlTheme>

</ResourceDictionary>

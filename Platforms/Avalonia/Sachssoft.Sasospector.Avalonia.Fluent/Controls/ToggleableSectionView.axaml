<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:views="using:Sachssoft.Sasospector.Views"
					x:ClassModifier="internal">

	<ControlTheme x:Key="{x:Type views:ToggleableSectionView}"
				  TargetType="views:ToggleableSectionView">

		<Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderMidBrush}"/>
		<Setter Property="BorderThickness" Value="{DynamicResource ThemeBorderThickness}"/>
		<Setter Property="Padding" Value="10"/>
		<Setter Property="Template">
			<ControlTemplate TargetType="views:ToggleableSectionView">
				<Expander Theme="{StaticResource InspectorSectionViewExpanderTheme}">
					<Expander.Header>
						<StackPanel Orientation="Horizontal">
							<CheckBox x:Name="ToggleCheckBox"
									  VerticalAlignment="Center"
									  IsChecked="{TemplateBinding IsChecked, Mode=TwoWay}"/>
							<ContentPresenter Content="{TemplateBinding Header}"
											  VerticalAlignment="Center"/>
						</StackPanel>
					</Expander.Header>
					<ItemsControl ItemsSource="{Binding $parent[views:ToggleableSectionView].Items}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Orientation="Vertical"
											Spacing="{Binding $parent[views:InspectorControl].PropertySpacing}" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
					</ItemsControl>
				</Expander>
			</ControlTemplate>
		</Setter>
		<Style Selector="^[Action=Enabled][IsChecked=True] /template/ ItemsControl">
			<Setter Property="IsEnabled" Value="True" />
		</Style>
		<Style Selector="^[Action=Enabled][IsChecked=False] /template/ ItemsControl">
			<Setter Property="IsEnabled" Value="False" />
		</Style>
		<Style Selector="^[Action=Visible][IsChecked=True] /template/ ItemsControl">
			<Setter Property="IsVisible" Value="True" />
		</Style>
		<Style Selector="^[Action=Visible][IsChecked=False] /template/ ItemsControl">
			<Setter Property="IsVisible" Value="False" />
		</Style>
	</ControlTheme>
</ResourceDictionary>

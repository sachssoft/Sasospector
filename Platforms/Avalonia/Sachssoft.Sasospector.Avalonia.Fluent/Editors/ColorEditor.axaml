<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:views="using:Sachssoft.Sasospector.Views"
					xmlns:converters="using:Sachssoft.Sasospector.Views.Converters"
					xmlns:editors="using:Sachssoft.Sasospector.Views.Editors"
					x:ClassModifier="internal">

	<converters:ColorToHexConverter x:Key="ColorToHexConverter" />
	
	<ControlTheme x:Key="{x:Type editors:ColorEditor}"
					  TargetType="editors:ColorEditor">
		<Setter Property="Template">
			<ControlTemplate TargetType="editors:ColorEditor">
				<Grid ColumnDefinitions="Auto,*,Auto,Auto">
					<Border Grid.Column="0"
							HorizontalAlignment="Stretch"
							Width="{StaticResource InspectorPropertyEditorWidth}"
							Height="{StaticResource InspectorPropertyEditorHeight}"
							Classes="colorBox">
						<Border.Background>
							<SolidColorBrush Color="{Binding SelectedColor, RelativeSource={RelativeSource AncestorType=editors:ColorEditor}, Mode=TwoWay}" />
						</Border.Background>
					</Border>
					<TextBox x:Name="PART_TextBox"
							 Text="{Binding SelectedColor, RelativeSource={RelativeSource AncestorType=editors:ColorEditor}, Converter={StaticResource ColorToHexConverter}, Mode=TwoWay}"
							 HorizontalAlignment="Stretch"
							 Grid.Column="1"/>
					<Button x:Name="PART_PickButton"
							Command="{Binding PickAction.Command, RelativeSource={RelativeSource TemplatedParent}}"
							CommandParameter="{Binding PickAction.CommandParameter, RelativeSource={RelativeSource TemplatedParent}}"
							Tag="{Binding PickAction, RelativeSource={RelativeSource TemplatedParent}}"
							Grid.Column="2"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Center"
							Width="{StaticResource InspectorPropertyEditorWidth}"
							Height="{StaticResource InspectorPropertyEditorHeight}">
						<Viewbox Width="{StaticResource IconViewboxWidth}"
								 Height="{StaticResource IconViewboxHeight}"
								 HorizontalAlignment="Center"
								 VerticalAlignment="Center">
							<ContentPresenter Content="{Binding PickAction.Icon, RelativeSource={RelativeSource TemplatedParent}}" />
						</Viewbox>
					</Button>
					<Button x:Name="PART_CaptureButton"
							Command="{Binding CaptureAction.Command, RelativeSource={RelativeSource TemplatedParent}}"
							CommandParameter="{Binding CaptureAction.CommandParameter, RelativeSource={RelativeSource TemplatedParent}}"
							Tag="{Binding CaptureAction, RelativeSource={RelativeSource TemplatedParent}}"
							Grid.Column="3"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Center"
							Width="{StaticResource InspectorPropertyEditorWidth}"
							Height="{StaticResource InspectorPropertyEditorHeight}">
						<Viewbox Width="{StaticResource IconViewboxWidth}"
								 Height="{StaticResource IconViewboxHeight}"
								 HorizontalAlignment="Center"
								 VerticalAlignment="Center">
							<ContentPresenter Content="{Binding CaptureAction.Icon, RelativeSource={RelativeSource TemplatedParent}}" />
						</Viewbox>
					</Button>
				</Grid>
			</ControlTemplate>
		</Setter>
	</ControlTheme>
	
</ResourceDictionary>

<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:views="using:Sachssoft.Sasospector.Views"
					xmlns:editors="using:Sachssoft.Sasospector.Views.Editors"
					xmlns:fields="using:Sachssoft.Sasospector.Views.Fields"
					x:ClassModifier="internal">
	
	<ControlTheme x:Key="{x:Type editors:ListEditor}"
			      TargetType="editors:ListEditor">
		<Setter Property="Template">
			<ControlTemplate TargetType="editors:ListEditor"
							 x:DataType="editors:ListEditor">
				<Grid ColumnDefinitions="*,Auto"
					  ColumnSpacing="5">
					<ListBox x:Name="PART_List"
							 CornerRadius="{StaticResource InspectorPropertyBorderRadius}"
							 Background="{StaticResource InspectorPropertyFieldBackground}"
							 Grid.Column="0"
							 Height="200"
							 ItemsSource="{Binding ObservableItems, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=editors:ListEditor}}"
							 ItemTemplate="{TemplateBinding ItemTemplate}" />
					<StackPanel Orientation="Vertical"
								Grid.Column="1">
						<Button x:Name="PART_AddButton"
								Command="{Binding AddAction.Command, RelativeSource={RelativeSource TemplatedParent}}"
								CommandParameter="{Binding AddAction.CommandParameter, RelativeSource={RelativeSource TemplatedParent}}"
								Tag="{Binding AddAction, RelativeSource={RelativeSource TemplatedParent}}"
								Width="{StaticResource InspectorPropertyEditorWidth}"
								Height="{StaticResource InspectorPropertyEditorHeight}">
							<Viewbox Width="{StaticResource IconViewboxWidth}"
									 Height="{StaticResource IconViewboxHeight}">
								<ContentPresenter Content="{Binding AddAction.Icon, RelativeSource={RelativeSource TemplatedParent}}" />
							</Viewbox>
						</Button>
						<Button x:Name="PART_RemoveButton"
								Command="{Binding RemoveAction.Command, RelativeSource={RelativeSource TemplatedParent}}"
								CommandParameter="{Binding RemoveAction.CommandParameter, RelativeSource={RelativeSource TemplatedParent}}"
								Tag="{Binding RemoveAction, RelativeSource={RelativeSource TemplatedParent}}"
								Width="{StaticResource InspectorPropertyEditorWidth}"
								Height="{StaticResource InspectorPropertyEditorHeight}">
							<Viewbox Width="{StaticResource IconViewboxWidth}"
									 Height="{StaticResource IconViewboxHeight}">
								<ContentPresenter Content="{Binding RemoveAction.Icon, RelativeSource={RelativeSource TemplatedParent}}" />
							</Viewbox>
						</Button>
					</StackPanel>
				</Grid>
			</ControlTemplate>
		</Setter>
	</ControlTheme>
	
</ResourceDictionary>

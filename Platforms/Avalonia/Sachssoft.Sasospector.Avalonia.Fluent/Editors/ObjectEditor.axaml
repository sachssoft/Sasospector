<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:views="using:Sachssoft.Sasospector.Views"
					xmlns:converters="using:Sachssoft.Sasospector.Views.Converters"
					xmlns:editors="using:Sachssoft.Sasospector.Views.Editors"
					x:ClassModifier="internal">
	
	<ControlTheme x:Key="{x:Type editors:ObjectEditor}"
					  TargetType="editors:ObjectEditor">
		<Setter Property="InstanceFieldTemplate">
			<DataTemplate>
				<TextBlock Text="{Binding}" />
			</DataTemplate>
		</Setter>
		<Setter Property="Template">
			<ControlTemplate TargetType="editors:ObjectEditor">
			</ControlTemplate>
		</Setter>
		<Style Selector="^[EditorMode=Expandable]">
			<Setter Property="Template">
				<ControlTemplate TargetType="editors:ObjectEditor">
					<TextBlock Text="Expandable" />
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="^[EditorMode=Selectable]">
			<Setter Property="Template">
				<ControlTemplate TargetType="editors:ObjectEditor">
					<ComboBox HorizontalAlignment="Stretch"
							  Height="{StaticResource InspectorPropertyEditorHeight}"
							  ItemsSource="{TemplateBinding Instances}"
							  ItemTemplate="{TemplateBinding InstanceFieldTemplate}"
							  SelectedIndex="{TemplateBinding SelectedInstanceIndex, Mode=TwoWay}"/>
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="^[EditorMode=Browsable]">
			<Setter Property="Template">
				<ControlTemplate TargetType="editors:ObjectEditor">
					<TextBlock Text="Browse" />
				</ControlTemplate>
			</Setter>
		</Style>
	</ControlTheme>	
</ResourceDictionary>
